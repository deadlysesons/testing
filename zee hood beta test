    if not cam then return nil end
    local closest = nil
    local shortestDistance = math.huge
    local mousePos = UserInputService:GetMouseLocation()
    local w2sp = cam.WorldToScreenPoint
    for _, player in Players:GetPlayers() do
        if player == LocalPlayer then continue end
        local character = player.Character
        if not character then continue end
        local head = FFC(character, "Head")
        if not head then continue end
        local screenPos, onScreen = w2sp(cam, head.Position)
        if onScreen then
            local dx = screenPos.X - mousePos.X
            local dy = screenPos.Y - mousePos.Y
            local distSq = dx * dx + dy * dy
            if distSq < shortestDistance then
                shortestDistance = distSq
                closest = player
            end
        end
    end
    return closest
end

local function ShouldSkip(player)
    if ForceHitConfig.knockCheck and IsKnocked(player) then return true end
    if ForceHitConfig.protectedCheck and IsProtected(player) then return true end
    return false
end

local function RemoveHighlight()
    if TargetSystem._highlightInst then
        TargetSystem._highlightInst:Destroy()
        TargetSystem._highlightInst = nil
    end
    if TargetSystem._highlightCharConn then
        TargetSystem._highlightCharConn:Disconnect()
        TargetSystem._highlightCharConn = nil
    end
end

local function CreateHighlight(player)
    RemoveHighlight()
    if not player or not player.Character then return end
    local opts = getgenv().Options
    local fillTrans = ForceHitConfig.highlightFillTransparency
    local outlineTrans = ForceHitConfig.highlightOutlineTransparency
    if opts then
        if opts.HighlightFillColor then fillTrans = opts.HighlightFillColor.Transparency or fillTrans end
        if opts.HighlightOutlineColor then outlineTrans = opts.HighlightOutlineColor.Transparency or outlineTrans end
    end
    local hl = Instance_new("Highlight")
    hl.FillColor = ForceHitConfig.highlightFillColor
    hl.OutlineColor = ForceHitConfig.highlightOutlineColor
    hl.FillTransparency = fillTrans
    hl.OutlineTransparency = outlineTrans
    hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
    hl.Parent = player.Character
    TargetSystem._highlightInst = hl
    TargetSystem._highlightCharConn = player.CharacterAdded:Connect(function(newChar)
        task.wait(1)
        if TargetSystem._highlightInst and TargetSystem._highlightInst.Parent then
            TargetSystem._highlightInst.Parent = newChar
        end
    end)
end

local function StartSpectate(player)
    if TargetSystem._spectating then return end
    TargetSystem._spectating = true
    local cam = Workspace.CurrentCamera
    TargetSystem._savedCameraSubject = cam.CameraSubject
    if player.Character then
        cam.CameraSubject = player.Character
    end
    if TargetSystem._spectateCharConn then TargetSystem._spectateCharConn:Disconnect() end
    TargetSystem._spectateCharConn = player.CharacterAdded:Connect(function(newChar)
        task.wait(1)
        if TargetSystem._spectating and TargetSystem.targetplayer == player then
            Workspace.CurrentCamera.CameraSubject = newChar
        end
    end)
    if TargetSystem._spectateLocalConn then TargetSystem._spectateLocalConn:Disconnect() end
    TargetSystem._spectateLocalConn = LocalPlayer.CharacterAdded:Connect(function()
        task.wait(1)
        if TargetSystem._spectating and player and player.Character then
            Workspace.CurrentCamera.CameraSubject = player.Character
        end
    end)
end

local function StopSpectate()
    if not TargetSystem._spectating then return end
    TargetSystem._spectating = false
    if TargetSystem._spectateCharConn then
        TargetSystem._spectateCharConn:Disconnect()
        TargetSystem._spectateCharConn = nil
    end
    if TargetSystem._spectateLocalConn then
        TargetSystem._spectateLocalConn:Disconnect()
        TargetSystem._spectateLocalConn = nil
    end
    if LocalPlayer.Character then
        Workspace.CurrentCamera.CameraSubject = LocalPlayer.Character
    elseif TargetSystem._savedCameraSubject then
        Workspace.CurrentCamera.CameraSubject = TargetSystem._savedCameraSubject
    end
    TargetSystem._savedCameraSubject = nil
end

local function ClearTarget()
    TargetSystem.active = false
    TargetSystem.targetplayer = nil
    TargetSystem.targetpart = nil
    TargetSystem.targetposition = nil
    if TargetSystem._charAddedConn then
        TargetSystem._charAddedConn:Disconnect()
        TargetSystem._charAddedConn = nil
    end
    snapLine.Visible = false
    snapLineOutline.Visible = false
    targetInfoText.Visible = false
    StopSpectate()
    RemoveHighlight()
end

local function ToggleTarget()
    if not ForceHitConfig.enabled then return end
    if TargetSystem.active then
        ClearTarget()
    else
        local closestPlayer = GetClosestPlayer()
        if closestPlayer and not ShouldSkip(closestPlayer) then
            TargetSystem.active = true
            TargetSystem.targetplayer = closestPlayer
            TargetSystem.targetpart = FFC(closestPlayer.Character, "Head")
            if TargetSystem.targetpart then
                TargetSystem.targetposition = TargetSystem.targetpart.Position
            end

            if TargetSystem._charAddedConn then
                TargetSystem._charAddedConn:Disconnect()
            end
            TargetSystem._charAddedConn = closestPlayer.CharacterAdded:Connect(function(newChar)
                if ForceHitConfig.knockCheck then
                    ClearTarget()
                    return
                end
                local head = WFC(newChar, "Head", 10)
                if head and TargetSystem.active and TargetSystem.targetplayer == closestPlayer then
                    TargetSystem.targetpart = head
                    TargetSystem.targetposition = head.Position
                end
            end)

            if ForceHitConfig.highlight then
                CreateHighlight(closestPlayer)
            end
            if ForceHitConfig.spectate then
                StartSpectate(closestPlayer)
            end
        end
    end
end


    ConfigBox:AddInput("ConfigName", { Text = "Config Name", Default = "", Placeholder = "my_config", Finished = true })
    ConfigBox:AddDropdown("ConfigList", { Text = "Configs", Values = GetConfigs(), AllowNull = true })

    ConfigBox:AddButton("Save Config", function()
        local Name = Options.ConfigName and Options.ConfigName.Value
        if not Name or Name == "" then return Library:Notify("Enter a config name first!", 2) end
        SaveConfig(Name)
        Library:Notify("Config '" .. Name .. "' saved!", 2)
        Options.ConfigList:SetValues(GetConfigs())
    end)

    ConfigBox:AddButton("Load Config", function()
        local Name = Options.ConfigList and Options.ConfigList.Value
        if not Name or Name == "" then return Library:Notify("Select a config to load!", 2) end
        LoadConfig(Name)
        Library:Notify("Config '" .. Name .. "' loaded!", 2)
    end)

    ConfigBox:AddButton({ Text = "Delete Config", DoubleClick = true, Func = function()
        local Name = Options.ConfigList and Options.ConfigList.Value
        if not Name or Name == "" then return Library:Notify("Select a config to delete!", 2) end
        DeleteConfig(Name)
        Library:Notify("Config '" .. Name .. "' deleted!", 2)
        Options.ConfigList:SetValues(GetConfigs())
    end })

    ConfigBox:AddButton("Refresh List", function() Options.ConfigList:SetValues(GetConfigs()); Library:Notify("Config list refreshed!", 2) end)

    local ThemeBox = TabSettings:AddRightGroupbox("Theme Colors")

    local function ThemeCallback(Key)
        return function(Value)
            Library[Key] = Value
            if Key == "AccentColor" then Library.AccentColorDark = Library:GetDarkerColor(Value) end
            Library:UpdateColorsUsingRegistry()
        end
    end

    ThemeBox:AddLabel("Accent"):AddColorPicker("AccentPicker", { Default = Library.AccentColor, Title = "Accent Color", Callback = ThemeCallback("AccentColor") })
    ThemeBox:AddLabel("Main"):AddColorPicker("MainPicker", { Default = Library.MainColor, Title = "Main Color", Callback = ThemeCallback("MainColor") })

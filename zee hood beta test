do
    local Vec3 = Vector3.new
    local chamsEdges = {
        {1,2},{2,4},{4,3},{3,1},
        {5,6},{6,8},{8,7},{7,5},
        {1,5},{2,6},{3,7},{4,8},
    }

    local function removeAdorns(part)
        local children = part:GetChildren()
        for i = 1, #children do
            local obj = children[i]
            if obj.Name == "Chams" or obj.Name == "Glow" then
                obj:Destroy()
            end
        end
    end

    local function cornerVec(part)
        local s = part.Size * 0.5
        return {
            Vec3(-s.X, -s.Y, -s.Z), Vec3(s.X, -s.Y, -s.Z),
            Vec3(-s.X, -s.Y,  s.Z), Vec3(s.X, -s.Y,  s.Z),
            Vec3(-s.X,  s.Y, -s.Z), Vec3(s.X,  s.Y, -s.Z),
            Vec3(-s.X,  s.Y,  s.Z), Vec3(s.X,  s.Y,  s.Z),
        }
    end

    local function clearAllChams()
        for _, player in Players:GetPlayers() do
            if player == LocalPlayer then continue end
            local char = player.Character
            if not char then continue end
            for _, part in char:GetChildren() do
                if part:IsA("BasePart") then
                    removeAdorns(part)
                end
            end
        end
    end

    ESPSettings.Chams._clearAll = clearAllChams

    task.spawn(function()
        while task.wait(2) do
            if not ESPSettings.Chams.Enabled then continue end
            local mainColor = ESPSettings.Chams.Color
            local trans = ESPSettings.Chams.Transparency
            local thickness = ESPSettings.Chams.Thickness

            local myChar = LocalPlayer.Character
            local myRoot = myChar and myChar:FindFirstChild("HumanoidRootPart")
            local myPos = myRoot and myRoot.Position

            for _, player in Players:GetPlayers() do
                if player == LocalPlayer then continue end
                local char = player.Character
                if not char then continue end

                local root = char:FindFirstChild("HumanoidRootPart")
                local tooFar = true
                if myPos and root then
                    local delta = root.Position - myPos
                    tooFar = delta:Dot(delta) > ESP_MAX_DIST_SQ
                end
                if tooFar then
                    for _, p in char:GetChildren() do
                        if p:IsA("BasePart") then removeAdorns(p) end
                    end
                    continue
                end

                for _, part in char:GetChildren() do
                    if not part:IsA("BasePart") or part.Transparency >= 1 then continue end

                    removeAdorns(part)

                    local isHead = part.Name == "Head" or part.Name == "FakeHead"

                    local glowAd
                    if isHead then
                        glowAd = Instance_new("CylinderHandleAdornment")
                        glowAd.Height = part.Size.Y + 0.03
                        glowAd.Radius = (part.Size.X * 0.5) + 0.03
                        glowAd.CFrame = CFrame_new(Vec3(), Vec3(0, 1, 0))
                    else
                        glowAd = Instance_new("BoxHandleAdornment")
                        glowAd.Size = part.Size + Vec3(0.03, 0.03, 0.03)
                    end
                    glowAd.Name = "Glow"
                    glowAd.Adornee = part
                    glowAd.AlwaysOnTop = true
                    glowAd.ZIndex = 9
                    glowAd.Color3 = Color3_fromRGB(mainColor.R * 1275, mainColor.G * 1275, mainColor.B * 1275)
                    glowAd.Transparency = -1
                    glowAd.Shading = Enum.AdornShading.XRayShaded
                    glowAd.Parent = part

                    local corners = cornerVec(part)
                    local points = {}
                    for ei = 1, #chamsEdges do
                        local edge = chamsEdges[ei]
                        points[#points + 1] = corners[edge[1]]
                        points[#points + 1] = corners[edge[2]]
                    end

                    local mainAd = Instance_new("WireframeHandleAdornment")
                    mainAd.Name = "Chams"
                    mainAd.Adornee = part
                    mainAd.AlwaysOnTop = true
                    mainAd.Thickness = thickness
                    mainAd.ZIndex = 10
                    mainAd.Color3 = mainColor
                    mainAd.Transparency = trans
                    mainAd.Parent = part
                    mainAd:AddLines(points)
                end
            end
        end
    end)
end


RunService.RenderStepped:Connect(function()
    if not TargetSystem.active then
        if TargetSystem._snapVisible then
            TargetSystem._snapVisible = false
            snapLine.Visible = false
            snapLineOutline.Visible = false
        end
        return
    end

    local tp = TargetSystem.targetplayer
    if not tp or not tp.Parent then
        ClearTarget()
        return
    end

    if ForceHitConfig.knockCheck and IsKnocked(tp) then
        ClearTarget()
        return
    end

    local char = tp.Character
    if char then
        if not TargetSystem.targetpart or not TargetSystem.targetpart.Parent then
            TargetSystem.targetpart = FFC(char, "Head")
        end
        if TargetSystem.targetpart then
            TargetSystem.targetposition = TargetSystem.targetpart.Position
        end
    else
        TargetSystem.targetpart = nil
    end

    if ForceHitConfig.targetInfo and char then
        local hum = char:FindFirstChildOfClass("Humanoid")
        if hum and hum.Health > 0 then
            local mousePos = UserInputService:GetMouseLocation()
            targetInfoText.Position = Vector2_new(mousePos.X + 10, mousePos.Y + 30)
            targetInfoText.Text = string.format("%s  %.0f/%.0f", tp.DisplayName, m_floor(hum.Health), m_floor(hum.MaxHealth))
            targetInfoText.Visible = true
        else
            targetInfoText.Visible = false
        end
    elseif targetInfoText.Visible then
        targetInfoText.Visible = false
    end

    local canShow = char and TargetSystem.targetpart and not ShouldSkip(tp)

    if canShow and ForceHitConfig.showSnapLine and TargetSystem.targetposition then
        local cam = Workspace.CurrentCamera
        if cam then
            local screenPos, onScreen = cam:WorldToViewportPoint(TargetSystem.targetposition)
            if onScreen then
                local mousePos = UserInputService:GetMouseLocation()
                local toPos = Vector2_new(screenPos.X, screenPos.Y)
                snapLineOutline.From = mousePos
                snapLineOutline.To = toPos
                snapLine.From = mousePos
                snapLine.To = toPos
                if not TargetSystem._snapVisible then
                    TargetSystem._snapVisible = true
                    snapLineOutline.Visible = true
                    snapLineOutline.ZIndex = 1
                    snapLine.Visible = true
                    snapLine.ZIndex = 2
                end
                return
            end
        end
    end

    if TargetSystem._snapVisible then
        TargetSystem._snapVisible = false
        snapLine.Visible = false
        snapLineOutline.Visible = false
    end
end)
end


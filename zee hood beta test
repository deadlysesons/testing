local function setupToolTracking(entry, char)
    if entry._toolAddConn then entry._toolAddConn:Disconnect() end
    if entry._toolRemConn then entry._toolRemConn:Disconnect() end

    entry.tool = ESPSettings._noneStr
    entry._cachedWeapon = ESPSettings._noneStr
    entry.weaponText.Text = ESPSettings._noneStr

    if not char then return end

    local children = char:GetChildren()
    for ci = 1, #children do
        local child = children[ci]
        if IsA_m(child, "Tool") then
            entry.tool = child.Name
            local cw = applyCase(child.Name)
            entry._cachedWeapon = cw
            entry.weaponText.Text = cw
            break
        end
    end

    entry._toolAddConn = char.ChildAdded:Connect(function(child)
        if IsA_m(child, "Tool") then
            entry.tool = child.Name
            local cw = applyCase(child.Name)
            entry._cachedWeapon = cw
            entry.weaponText.Text = cw
        end
    end)

    entry._toolRemConn = char.ChildRemoved:Connect(function(child)
        if IsA_m(child, "Tool") then
            entry.tool = ESPSettings._noneStr
            entry._cachedWeapon = ESPSettings._noneStr
            entry.weaponText.Text = ESPSettings._noneStr
        end
    end)
end


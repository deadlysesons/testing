do
    local GetConfigs = LPH_NO_VIRTUALIZE(function()
        EnsureFolder()
        local Configs = {}
        for _, File in next, listfiles(SAVE_FOLDER) do
            local Name = File:match("([^/\\]+)%.json$")
            if Name and Name ~= "theme" then table.insert(Configs, Name) end
        end
        return Configs
    end)

    local SaveConfig = LPH_NO_VIRTUALIZE(function(Name)
        EnsureFolder()
        local Toggles = getgenv().Toggles
        local Options = getgenv().Options
        local Data = {}
        for Idx, Toggle in next, Toggles do
            if Idx ~= "KeybindListToggle" and Idx ~= "WatermarkToggle" then
                Data[Idx] = { Type = "Toggle", Value = Toggle.Value }
            end
        end
        for Idx, Option in next, Options do
            if Option.Type == "Slider" then
                Data[Idx] = { Type = "Slider", Value = Option.Value }
            elseif Option.Type == "Dropdown" then
                Data[Idx] = { Type = "Dropdown", Value = Option.Value, Multi = Option.Multi }
            elseif Option.Type == "Input" then
                Data[Idx] = { Type = "Input", Value = Option.Value }
            elseif Option.Type == "ColorPicker" then
                Data[Idx] = { Type = "ColorPicker", Value = {Option.Value.R, Option.Value.G, Option.Value.B}, Transparency = Option.Transparency }
            elseif Option.Type == "KeyPicker" then
                Data[Idx] = { Type = "KeyPicker", Value = Option.Value, Mode = Option.Mode }
            end
        end
        writefile(SAVE_FOLDER .. "/" .. Name .. ".json", HttpService:JSONEncode(Data))
    end)

    local LoadConfig = LPH_NO_VIRTUALIZE(function(Name)
        EnsureFolder()
        local Toggles = getgenv().Toggles
        local Options = getgenv().Options
        local Path = SAVE_FOLDER .. "/" .. Name .. ".json"
        if not isfile(Path) then return end
        local Success, Data = pcall(HttpService.JSONDecode, HttpService, readfile(Path))
        if not Success or type(Data) ~= "table" then return end
        for Idx, Info in next, Data do
            pcall(function()
                if Info.Type == "Toggle" and Toggles[Idx] then
                    Toggles[Idx]:SetValue(Info.Value)
                elseif Options[Idx] then
                    if Info.Type == "ColorPicker" then
                        Options[Idx]:SetValueRGB(Color3.new(Info.Value[1], Info.Value[2], Info.Value[3]), Info.Transparency)
                    elseif Info.Type == "KeyPicker" then
                        Options[Idx]:SetValue({Info.Value, Info.Mode})
                    else
                        Options[Idx]:SetValue(Info.Value)
                    end
                end
            end)
        end
    end)

    local DeleteConfig = LPH_NO_VIRTUALIZE(function(Name)
        EnsureFolder()
        local Path = SAVE_FOLDER .. "/" .. Name .. ".json"
        if isfile(Path) then delfile(Path) end
    end)

    local MenuBox = TabSettings:AddLeftGroupbox("Interface")


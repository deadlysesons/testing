local function desyncIsVisible(part)
	return part:IsA("BasePart") and part.Name ~= "HumanoidRootPart" and part.Transparency < 1
end

local function desyncGhostOn(char)
	if desync.ghost then return end
	desync.ghost = true
	desync.cache = {}

	local head = char:FindFirstChild("Head")
	if head then
		desync.cache[head] = { trans = head.Transparency }
		head.Transparency = 1
		local face = head:FindFirstChild("face") or head:FindFirstChild("Face")
		if face and face:IsA("Decal") then
			desync.cache[face] = { trans = face.Transparency }
			face.Transparency = 1
		end
	end

	for _, v in ipairs(char:GetDescendants()) do
		if desyncIsVisible(v) and v.Name ~= "Head" then
			desync.cache[v] = { trans = v.Transparency, mat = v.Material, col = v.Color }
			v.Transparency = math.clamp(v.Transparency + 0.15, 0, 0.6)
			v.Material = Enum.Material.ForceField
			v.Color = Color3.new(1, 1, 1)
		end
	end
end

local function desyncGhostOff()
	if not desync.ghost then return end
	desync.ghost = false
	for p, d in pairs(desync.cache) do
		if p and p.Parent then
			if d.trans then p.Transparency = d.trans end
			if d.mat then p.Material = d.mat end
			if d.col then p.Color = d.col end
		end
	end
	desync.cache = {}
end

local function stopDesync()
	for _, c in pairs(desyncCons) do c:Disconnect() end
	desyncCons = {}
	pcall(function() RunService:UnbindFromRenderStep("desyncfix") end)
	desyncGhostOff()
	desync.paused = false

	local char = LocalPlayer.Character
	local root = char and char:FindFirstChild("HumanoidRootPart")
	if root and desyncCF then
		root.CFrame = desyncCF
		root.AssemblyLinearVelocity = desyncVel
	end
	desyncCF = nil
	desyncVel = nil
end

local function startDesync()
	stopDesync()
	local char = LocalPlayer.Character
	if not char then return end
	local root = char:WaitForChild("HumanoidRootPart", 2)
	local hum = char:FindFirstChildOfClass("Humanoid")
	if not root or not hum then return end

	desyncGhostOn(char)
	desyncCF = root.CFrame
	desyncVel = root.AssemblyLinearVelocity
	desync.safecf = desyncCF

	desyncCons.died = hum.Died:Connect(stopDesync)
	desyncCons.heartbeat = RunService.Heartbeat:Connect(function()
		if not root or not root.Parent then return end

		local be = char:FindFirstChild("BodyEffects")
		local isko = be and be:FindFirstChild("K.O") and be["K.O"].Value
		if isko then
			desync.safecf = root.CFrame
			desyncCF = root.CFrame
			desyncVel = root.AssemblyLinearVelocity
			return
		end

		local currentcf = root.CFrame
		local currentvel = root.AssemblyLinearVelocity

		desync.safecf = currentcf
		desyncVel = currentvel
		desyncCF = currentcf

		root.CFrame = CFrame_new(desyncRand:NextNumber(-1e6, 1e6), 5e7 + desyncRand:NextNumber(0, 10000), desyncRand:NextNumber(-1e6, 1e6))
		if desyncVel.Magnitude < 1 then
			root.AssemblyLinearVelocity = Vector3.new(desyncRand:NextNumber(-5000, 5000), desyncRand:NextNumber(-5000, 5000), desyncRand:NextNumber(-5000, 5000))
		end
	end)

	RunService:BindToRenderStep("desyncfix", Enum.RenderPriority.Camera.Value - 1, function()
		if not root or not root.Parent then return end
		if desync.paused then return end

		local be = char:FindFirstChild("BodyEffects")
		local isko = be and be:FindFirstChild("K.O") and be["K.O"].Value
		if isko then return end

		if desyncCF then
			root.CFrame = desyncCF
			if desyncVel and desyncVel.Magnitude < 1 then root.AssemblyLinearVelocity = desyncVel end
		end
	end)
end


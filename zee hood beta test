local function CreateBeamTracer(startPos, endPos)
    local color = TracerState.Color
    local size = TracerState.Size
    local opacity = TracerState.Opacity

    local att1 = Instance_new("Attachment")
    att1.WorldPosition = startPos
    att1.Parent = Terrain

    local att2 = Instance_new("Attachment")
    att2.WorldPosition = endPos
    att2.Parent = Terrain

    local beam = Instance_new("Beam")
    beam.Attachment0 = att1
    beam.Attachment1 = att2
    beam.FaceCamera = true
    beam.Color = ColorSequence_new(color)
    beam.Texture = TracerState.Texture
    beam.LightEmission = 1
    beam.Transparency = NumberSequence_new(1 - opacity)
    beam.Width0 = size
    beam.Width1 = size
    beam.Parent = Terrain

    task.delay(TracerState.Lifetime, function()
        if beam.Parent then
            local tw = TweenService:Create(beam, TracerState.FadeInfo, TracerState.FadeGoal)
            tw:Play()
            tw.Completed:Once(function()
                beam:Destroy()
                att1:Destroy()
                att2:Destroy()
            end)
        else

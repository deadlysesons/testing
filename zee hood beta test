    GunModsBox:AddToggle("NoSpreadEnabled", {
        Text = "No Spread",
        Default = false,
        Tooltip = "Remove bullet spread from shotguns",
        Callback = function(Value) NoSpreadConfig.enabled = Value end
    })

    local applyNoDelayToTool = LPH_NO_VIRTUALIZE(function(tool)
        local NoDelayConfig = shared.__NoDelayConfig
        if not tool or not tool:IsA("Tool") then return end
        pcall(function()
            tool:SetAttribute("Cooldown", nil)
            local cdObj = tool:FindFirstChild("ShootingCooldown")
            if not cdObj then return end
            local originalCd = cdObj.Value
            if originalCd <= 0 then return end
            local cons = getconnections(tool.Activated)
            for _, cn in pairs(cons) do
                local fn = cn.Function
                if not fn then continue end
                for idx, val in pairs(debug.getupvalues(fn)) do
                    if type(val) == "number" and val == originalCd then
                        NoDelayConfig.origCooldowns[tool] = { fn = fn, idx = idx, val = originalCd }
                        debug.setupvalue(fn, idx, 0)
                        return
                    end
                end
            end
        end)
    end)

    local restoreDelayOnTool = LPH_NO_VIRTUALIZE(function(tool)
        local NoDelayConfig = shared.__NoDelayConfig
        if not tool or not tool:IsA("Tool") then return end
        local info = NoDelayConfig.origCooldowns[tool]
        if not info then return end
        pcall(function()
            debug.setupvalue(info.fn, info.idx, info.val)
        end)
        NoDelayConfig.origCooldowns[tool] = nil
    end)

    RunService.Heartbeat:Connect(function()
        if not NoDelayConfig.enabled then return end
        local char = LocalPlayer.Character
        if not char then return end
        local tool = char:FindFirstChildWhichIsA("Tool")
        if not tool then return end
        if tool:GetAttribute("Cooldown") ~= nil then
            tool:SetAttribute("Cooldown", nil)
        end
    end)

    GunModsBox:AddToggle("NoDelayEnabled", {
        Text = "No Delay",
        Default = false,
        Tooltip = "Remove shooting cooldown from guns",
        Callback = function(Value)
            NoDelayConfig.enabled = Value
            local char = LocalPlayer.Character
            if not char then return end
            if Value then
                for _, child in ipairs(char:GetChildren()) do
                    if child:IsA("Tool") then applyNoDelayToTool(child) end
                end
                for _, child in ipairs(LocalPlayer.Backpack:GetChildren()) do
                    if child:IsA("Tool") then applyNoDelayToTool(child) end
                end
            else
                for _, child in ipairs(char:GetChildren()) do
                    if child:IsA("Tool") then restoreDelayOnTool(child) end
                end
                for _, child in ipairs(LocalPlayer.Backpack:GetChildren()) do
                    if child:IsA("Tool") then restoreDelayOnTool(child) end
                end
            end
        end
    })

    LocalPlayer.CharacterAdded:Connect(function(char)
        NoDelayConfig.origCooldowns = {}
        if not NoDelayConfig.enabled then return end
        char.ChildAdded:Connect(function(child)
            if NoDelayConfig.enabled and child:IsA("Tool") then
                task.wait(0.3)
                applyNoDelayToTool(child)
            end
        end)
    end)

    local char = LocalPlayer.Character
    if char then
        char.ChildAdded:Connect(function(child)
            if NoDelayConfig.enabled and child:IsA("Tool") then
                task.wait(0.3)

local function updateAllESP()
    local count = espState.count
    if not ESPSettings.Enabled then
        for i = 1, count do
            local e = espState.entries[i]
            if e._visible then
                e._visible = false
                e.holder.Visible = false

            end
        end
        return
    end

    local cam = Workspace.CurrentCamera
    if not cam then return end

    local camCF = cam.CFrame
    local camPos = camCF.Position
    local camPosX, camPosY, camPosZ = camPos.X, camPos.Y, camPos.Z
    local w2vp = cam.WorldToViewportPoint
    local vY = cam.ViewportSize.Y
    local maxDistSq = ESP_MAX_DIST_SQ

    local healthEnabled = ESPSettings.HealthBar.Enabled
    local distEnabled = ESPSettings.Distance.Enabled
    local flagsEnabled = ESPSettings.Flags.Enabled
    local teamCheck = ESPSettings.TeamCheck
    local myGroup, myTeam
    if teamCheck then
        myGroup = LocalPlayer:GetAttribute("MatchGroupId")
        myTeam = LocalPlayer:GetAttribute("MatchTeamId")
    end

    for i = 1, count do
        local e = espState.entries[i]

        if teamCheck and myGroup ~= nil and myTeam ~= nil then
            local tg = e.player:GetAttribute("MatchGroupId")
            local tt = e.player:GetAttribute("MatchTeamId")
            if tg == myGroup and tt == myTeam then
                if e._visible then
                    e._visible = false
                    e.holder.Visible = false
    
                end
                continue
            end
        end

        local root = e.rootPart
        if not root or not root.Parent then
            local char = e.character
            if char then
                root = FFC(char, "HumanoidRootPart")
                e.rootPart = root
                if not root then
                    local hum = e.humanoid
                    if not hum or not hum.Parent then
                        hum = FFCWIA(char, "Humanoid")
                        e.humanoid = hum
                    end
                    if hum then
                        root = hum.RootPart
                        e.rootPart = root
                    end
                end
            end
            if not root then
                if e._visible then
                    e._visible = false
                    e.holder.Visible = false
    
                end
                continue
            end
        end

        local rootPos = root.Position
        local dx = rootPos.X - camPosX
        local dy = rootPos.Y - camPosY
        local dz = rootPos.Z - camPosZ
        local distSq = dx * dx + dy * dy + dz * dz

        if distSq > maxDistSq then
            if e._visible then
                e._visible = false
                e.holder.Visible = false

            end
            continue
        end

        local screenPos, onScreen = w2vp(cam, rootPos)

        if not onScreen then
            if e._visible then
                e._visible = false
                e.holder.Visible = false

            end
            continue
        end

        local depth = screenPos.Z
        local scale = vY / depth
        local boxW = m_floor(3 * scale)
        local boxH = m_floor(4.5 * scale)
        local sX = m_floor(screenPos.X - boxW * 0.5)
        local sY = m_floor(screenPos.Y - boxH * 0.5)

        if not e._visible then
            e._visible = true
            e.holder.Visible = true
        end

        if sX ~= e._lastX or sY ~= e._lastY then
            e._lastX = sX
            e._lastY = sY
            e.holder.Position = UDim2_fromOffset(sX, sY)
        end

        if boxW ~= e._lastW or boxH ~= e._lastH then
            e._lastW = boxW
            e._lastH = boxH
            e.holder.Size = UDim2_fromOffset(boxW, boxH)
        end

        if healthEnabled then
            local hum = e.humanoid
            if not hum or not hum.Parent then
                local char = e.character
                if char then
                    hum = FFCWIA(char, "Humanoid")
                    e.humanoid = hum
                end
            end
            if hum then
                local health = hum.Health
                local maxHealth = hum.MaxHealth
                local barVal = health / maxHealth
                local barRound = m_floor(barVal * 100)

                if barRound ~= e._lastBar then
                    e._lastBar = barRound
                    e.healthFill.Size = UDim2_new(1, 0, barVal, 0)
                    e.healthGrad.Offset = Vector2_new(0, barVal - 1)

                    local showText = health ~= maxHealth
                    e.healthText.Visible = showText
                    if showText then
                        e.healthText.Text = string.format("%d", health)
                    end
                end
            end
        end

        if distEnabled then
            local dist = m_floor(m_sqrt(distSq))
            local distStr = dist .. ESPSettings._distEnding
            if distStr ~= e._lastDistText then
                e._lastDistText = distStr
                e.distText.Text = distStr
            end
        end

        if flagsEnabled then
            local hum = e.humanoid
            local flags = ""
            if hum and hum.Parent then
                local md = hum.MoveDirection
                local moving = md.X ~= 0 or md.Y ~= 0 or md.Z ~= 0
                local jumping = hum.Jump

                if moving and jumping then
                    flags = ESPSettings._flagBoth
                elseif moving then
                    flags = ESPSettings._flagMoving
                elseif jumping then
                    flags = ESPSettings._flagJumping
                end
            end
            if flags ~= e._lastFlagsText then
                e._lastFlagsText = flags
                e.flagsText.Text = flags
            end
        end
    end
end

